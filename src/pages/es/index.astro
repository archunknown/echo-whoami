---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Hero from "../../components/Hero.astro";
import ProjectCard from "../../components/ProjectCard.astro";
import CertificationCard from "../../components/CertificationCard.astro";
import StackSection from "../../components/StackSection.astro";
import ContactForm from "../../components/ContactForm.astro";
import Footer from "../../components/Footer.astro";
import {
    getProfile,
    getFeaturedProjects,
    getPublishedProjects,
    getPublishedCertifications,
    getAllTechnologies,
    getPublishedEducation,
} from "../../services/api";
import { t } from "../../utils/i18n";
import { marked } from "marked";

const profile = await getProfile();
const featuredProjects = await getFeaturedProjects().catch(() => []);
const allProjects = await getPublishedProjects().catch(() => []);
const certifications = await getPublishedCertifications().catch(() => []);
const technologies = await getAllTechnologies().catch(() => []);
const educationEntries = await getPublishedEducation().catch(() => []);

const translatedProfile = profile
    ? {
          ...profile,
          bio: t(profile.bio, "es"),
          resume_url: t(profile.resume_url, "es"),
      }
    : null;

const architectureText = profile?.architecture_text as {
    es?: string;
    en?: string;
};
const dataAnalyticsText = profile?.data_analytics_text as {
    es?: string;
    en?: string;
};

// Featured → fallback a todos los publicados
const hasFeatured = (featuredProjects?.length ?? 0) > 0;
const initialProjects = hasFeatured ? featuredProjects : (allProjects?.slice(0, 4) ?? []);
const remainingProjects = hasFeatured
    ? allProjects?.filter(p => !featuredProjects?.find(f => f.id === p.id)) ?? []
    : allProjects?.slice(4) ?? [];

const translateProject = (project: any) => ({
    ...project,
    title: t(project.title, "es"),
    summary: t(project.summary, "es"),
    problem: t(project.problem, "es"),
    architecture: t(project.architecture, "es"),
    outcome: t(project.outcome, "es"),
});

const translatedInitialProjects = initialProjects.map(translateProject);
const translatedRemainingProjects = remainingProjects.map(translateProject);

const translatedCertifications = certifications?.map((cert) => ({
    ...cert,
    title: t(cert.title, "es"),
}));

// Educación agrupada por categoría
const educationCategories = ['university', 'technical', 'certification', 'complementary'] as const;
type EduCat = typeof educationCategories[number];
const groupedEducation = educationCategories.reduce((acc, cat) => {
    acc[cat] = (educationEntries ?? []).filter((e: any) => e.category === cat).map((e: any) => ({
        ...e,
        title: t(e.title, 'es'),
        institution: t(e.institution, 'es'),
        description: e.description ? t(e.description, 'es') : null,
    }));
    return acc;
}, {} as Record<EduCat, any[]>);
const hasEducation = Object.values(groupedEducation).some(g => g.length > 0);

const uiDictionary = {
    projects: "Ver proyectos",
    github: "Ver GitHub",
    resume: "Descargar CV",
    problem: "Problema",
    architecture: "Arquitectura",
    outcome: "Resultado",
    privateRepo: "Privado",
    certificationsTitle: "Certificaciones",
    stackTitle: "Stack Tecnológico",
    architectureTitle: "Arquitectura de Sistemas",
    dataTitle: "Datos y Analítica",
    viewCredential: "Ver Credencial",
    contactTitle: "Ponte en Contacto",
    contactName: "Nombre Completo",
    contactEmail: "Correo Electrónico",
    contactMessage: "Tu Mensaje",
    contactSubmit: "Enviar Mensaje",
    contactSuccess: "¡Mensaje enviado correctamente! Me pondré en contacto pronto.",
    contactError: "Hubo un error al enviar el mensaje. Por favor intenta de nuevo.",
    showMore: "Ver todos los proyectos",
    educationTitle: "Educación",
    educationCategories: {
        university: "Universidad",
        technical: "Formación Técnica",
        certification: "Certificaciones y Cursos",
        complementary: "Complementario",
    } as Record<string, string>,
};
---

<Layout
    title="echo-whoami — Portafolio"
    lang="es"
    description="Ingeniero de software y especialista en datos. Proyectos, stack y contacto."
>
    <div class="min-h-screen flex flex-col font-sans">
        <Header lang="es" />
        <main class="grow flex flex-col font-sans">
            {
                translatedProfile && (
                    <Hero
                        bio={translatedProfile.bio}
                        resumeUrl={translatedProfile.resume_url || "#"}
                        githubUrl={translatedProfile.github_url || "#"}
                        avatarUrl={profile?.avatar_url || undefined}
                        displayName={profile?.display_name || undefined}
                        t={uiDictionary}
                    />
                )
            }

            <section
                id="proyectos"
                class="max-w-5xl mx-auto px-6 py-20 w-full flex flex-col gap-10 reveal-hidden"
            >
                <div class="flex flex-col gap-2">
                    <p
                        class="font-mono text-xs tracking-widest"
                        style="color: var(--text-muted);"
                    >
                        002 — trabajo
                    </p>
                    <h2
                        class="text-3xl md:text-4xl font-black tracking-tight"
                        style="color: var(--text-primary);"
                    >
                        {uiDictionary.projects}
                    </h2>
                </div>

                <!-- Proyectos iniciales (destacados) -->
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-6" id="projects-initial-es">
                    {
                        translatedInitialProjects.map((project) => (
                            <ProjectCard project={project} t={uiDictionary} />
                        ))
                    }
                </div>

                <!-- Proyectos restantes (ocultos hasta "ver más") -->
                {translatedRemainingProjects.length > 0 && (
                    <>
                        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 hidden" id="projects-more-es">
                            {translatedRemainingProjects.map((project) => (
                                <ProjectCard project={project} t={uiDictionary} />
                            ))}
                        </div>
                        <div class="flex justify-center">
                            <button
                                id="show-more-btn-es"
                                class="font-mono text-xs tracking-widest px-8 py-3 transition-all duration-200"
                                style="border: 1px solid var(--border-default); color: var(--text-secondary); background: transparent;"
                            >
                                {uiDictionary.showMore} ({translatedRemainingProjects.length})
                            </button>
                        </div>
                    </>
                )}
            </section>

            <script>
                const btn = document.getElementById('show-more-btn-es');
                const more = document.getElementById('projects-more-es');
                if (btn && more) {
                    btn.addEventListener('click', () => {
                        more.classList.remove('hidden');
                        btn.parentElement?.remove();
                    });
                }
            </script>

            {
                translatedCertifications && translatedCertifications.length > 0 && (
                    <section
                        id="certificaciones"
                        class="max-w-5xl mx-auto px-6 py-20 w-full flex flex-col gap-10 reveal-hidden"
                        style="border-top: 1px solid var(--border-subtle);"
                    >
                        <div class="flex flex-col gap-2">
                            <p
                                class="font-mono text-xs tracking-widest"
                                style="color: var(--text-muted);"
                            >
                                003 — certificaciones
                            </p>
                            <h2
                                class="text-3xl md:text-4xl font-black tracking-tight"
                                style="color: var(--text-primary);"
                            >
                                {uiDictionary.certificationsTitle}
                            </h2>
                        </div>
                        <div class="flex flex-col">
                            {translatedCertifications.map((cert, i) => (
                                <CertificationCard
                                    certification={cert}
                                    index={i}
                                    t={uiDictionary}
                                />
                            ))}
                        </div>
                    </section>
                )
            }

            {
                technologies && technologies.length > 0 && (
                    <section
                        id="stack"
                        class="max-w-5xl mx-auto px-6 py-20 w-full reveal-hidden"
                        style="border-top: 1px solid var(--border-subtle);"
                    >
                        <div class="flex flex-col gap-2 mb-10">
                            <p
                                class="font-mono text-xs tracking-widest"
                                style="color: var(--text-muted);"
                            >
                                004 — stack
                            </p>
                            <h2
                                class="text-3xl md:text-4xl font-black tracking-tight"
                                style="color: var(--text-primary);"
                            >
                                {uiDictionary.stackTitle}
                            </h2>
                        </div>
                        <StackSection technologies={technologies} />
                    </section>
                )
            }

            {
                (architectureText?.es || profile?.architecture_image_url) && (
                    <section
                        id="arquitectura"
                        class="max-w-5xl mx-auto px-6 py-20 w-full reveal-hidden"
                        style="border-top: 1px solid var(--border-subtle);"
                    >
                        <div class="flex flex-col gap-2 mb-10">
                            <p
                                class="font-mono text-xs tracking-widest"
                                style="color: var(--text-muted);"
                            >
                                006 — arquitectura
                            </p>
                            <h2
                                class="text-3xl md:text-4xl font-black tracking-tight"
                                style="color: var(--text-primary);"
                            >
                                {uiDictionary.architectureTitle}
                            </h2>
                        </div>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
                            {architectureText?.es && (
                                <div
                                    set:html={marked.parse(architectureText.es)}
                                    class="text-sm leading-relaxed [&>p]:mb-4 [&>strong]:font-black [&>ul]:list-none [&>ul]:pl-0 [&>ul]:mb-4 [&>a]:underline"
                                    style="color: var(--text-secondary);"
                                />
                            )}
                            {profile?.architecture_image_url && (
                                <div
                                    class="w-full flex items-center justify-center p-4"
                                    style="border: 1px solid var(--border-subtle);"
                                >
                                    <img
                                        src={profile.architecture_image_url}
                                        alt="Diagrama de Arquitectura de Sistemas"
                                        loading="lazy"
                                        class="w-full h-auto max-h-[400px] object-contain"
                                        style="filter: grayscale(100%) contrast(1.1);"
                                    />
                                </div>
                            )}
                        </div>
                    </section>
                )
            }

            {
                (dataAnalyticsText?.es || profile?.data_analytics_image_url) && (
                    <section
                        id="datos-analitica"
                        class="max-w-5xl mx-auto px-6 py-20 w-full reveal-hidden"
                        style="border-top: 1px solid var(--border-subtle);"
                    >
                        <div class="flex flex-col gap-2 mb-10">
                            <p
                                class="font-mono text-xs tracking-widest"
                                style="color: var(--text-muted);"
                            >
                                007 — datos y analítica
                            </p>
                            <h2
                                class="text-3xl md:text-4xl font-black tracking-tight"
                                style="color: var(--text-primary);"
                            >
                                {uiDictionary.dataTitle}
                            </h2>
                        </div>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
                            {profile?.data_analytics_image_url && (
                                <div
                                    class="w-full flex items-center justify-center p-4 order-last md:order-first"
                                    style="border: 1px solid var(--border-subtle);"
                                >
                                    <img
                                        src={profile.data_analytics_image_url}
                                        alt="Métricas y Analítica de Datos"
                                        loading="lazy"
                                        class="w-full h-auto max-h-[400px] object-contain"
                                        style="filter: grayscale(100%) contrast(1.1);"
                                    />
                                </div>
                            )}
                            {dataAnalyticsText?.es && (
                                <div
                                    set:html={marked.parse(dataAnalyticsText.es)}
                                    class="text-sm leading-relaxed [&>p]:mb-4 [&>strong]:font-black [&>ul]:list-none [&>ul]:pl-0 [&>ul]:mb-4 [&>a]:underline"
                                    style="color: var(--text-secondary);"
                                />
                            )}
                        </div>
                    </section>
                )
            }

            {
                hasEducation && (
                    <section
                        id="educacion"
                        class="max-w-5xl mx-auto px-6 py-20 w-full reveal-hidden"
                        style="border-top: 1px solid var(--border-subtle);"
                    >
                        <div class="flex flex-col gap-2 mb-12">
                            <p class="font-mono text-xs tracking-widest" style="color: var(--text-muted);">
                                005 — educación
                            </p>
                            <h2 class="text-3xl md:text-4xl font-black tracking-tight" style="color: var(--text-primary);">
                                {uiDictionary.educationTitle}
                            </h2>
                        </div>
                        <div class="flex flex-col gap-12">
                            {educationCategories.map(cat => {
                                const entries = groupedEducation[cat];
                                if (!entries || entries.length === 0) return null;
                                return (
                                    <div>
                                        <p class="font-mono text-xs tracking-widest mb-6" style="color: var(--text-muted); border-bottom: 1px solid var(--border-subtle); padding-bottom: 0.5rem;">
                                            {uiDictionary.educationCategories[cat]}
                                        </p>
                                        <div class="relative">
                                            <div class="absolute left-0 top-0 bottom-0 w-px" style="background: var(--border-subtle); margin-left: 7px;"></div>
                                            <div class="flex flex-col gap-6">
                                                {entries.map((entry: any) => {
                                                    const startYear = entry.start_date ? new Date(entry.start_date).getFullYear() : null;
                                                    const endYear = entry.is_current ? 'presente' : entry.end_date ? new Date(entry.end_date).getFullYear() : null;
                                                    return (
                                                        <div class="pl-8 relative">
                                                            <div class="absolute left-0 w-3.5 h-3.5 rounded-full border" style="background: var(--bg-primary); border-color: var(--color-accent); top: 0.25rem;"></div>
                                                            <div class="flex flex-col gap-1">
                                                                <div class="flex flex-wrap items-baseline gap-3">
                                                                    <h3 class="text-base font-black tracking-tight" style="color: var(--text-primary);">{entry.title}</h3>
                                                                    {startYear && (
                                                                        <span class="font-mono text-xs" style="color: var(--text-muted);">
                                                                            {startYear}{endYear ? ` — ${endYear}` : ''}
                                                                        </span>
                                                                    )}
                                                                </div>
                                                                <p class="font-mono text-xs" style="color: var(--text-secondary);">{entry.institution}</p>
                                                                {entry.description && <p class="text-sm mt-1 leading-relaxed" style="color: var(--text-secondary);">{entry.description}</p>}
                                                                {entry.credential_url && (
                                                                    <a href={entry.credential_url} target="_blank" rel="noopener noreferrer" class="font-mono text-xs mt-1 transition-colors hover:opacity-80" style="color: var(--color-accent);">
                                                                        {uiDictionary.viewCredential} ↗
                                                                    </a>
                                                                )}
                                                            </div>
                                                        </div>
                                                    );
                                                })}
                                            </div>
                                        </div>
                                    </div>
                                );
                            })}
                        </div>
                    </section>
                )
            }

            <section
                id="contacto"
                class="max-w-5xl mx-auto px-6 py-20 w-full reveal-hidden"
                style="border-top: 1px solid var(--border-subtle);"
            >
                <ContactForm
                    t={{
                        title: uiDictionary.contactTitle,
                        nameLabel: uiDictionary.contactName,
                        emailLabel: uiDictionary.contactEmail,
                        messageLabel: uiDictionary.contactMessage,
                        submitText: uiDictionary.contactSubmit,
                        successMessage: uiDictionary.contactSuccess,
                        errorMessage: uiDictionary.contactError,
                    }}
                />
            </section>
        </main>
        <Footer />
    </div>
</Layout>
