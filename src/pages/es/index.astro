---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Hero from "../../components/Hero.astro";
import ProjectCard from "../../components/ProjectCard.astro";
import StackSection from "../../components/StackSection.astro";
import ContactForm from "../../components/ContactForm.astro";
import EducationTimeline from "../../components/EducationTimeline.astro";
import Footer from "../../components/Footer.astro";
import {
    getProfile,
    getFeaturedProjects,
    getPublishedProjects,
    getAllTechnologies,
    getPublishedEducation,
} from "../../services/api";
import { t } from "../../utils/i18n";

const profile = await getProfile();
const featuredProjects = await getFeaturedProjects().catch(() => []);
const allProjects = await getPublishedProjects().catch(() => []);
const technologies = await getAllTechnologies().catch(() => []);
const educationEntries = await getPublishedEducation().catch(() => []);

const translatedProfile = profile
    ? {
          ...profile,
          bio: t(profile.bio, "es"),
          resume_url: t(profile.resume_url, "es"),
      }
    : null;

const hasFeatured = (featuredProjects?.length ?? 0) > 0;
const initialProjects = hasFeatured
    ? featuredProjects
    : (allProjects?.slice(0, 4) ?? []);
const remainingProjects = hasFeatured
    ? (allProjects?.filter(
          (p) => !featuredProjects?.find((f) => f.id === p.id),
      ) ?? [])
    : (allProjects?.slice(4) ?? []);

const translateProject = (project: any) => ({
    ...project,
    title: t(project.title, "es"),
    summary: t(project.summary, "es"),
    problem: t(project.problem, "es"),
    architecture: t(project.architecture, "es"),
    outcome: t(project.outcome, "es"),
});

const allDisplayProjects = [...initialProjects, ...remainingProjects].map(translateProject);

const EDUCATION_CATEGORY_LABELS: Record<string, string> = {
    university: "Universidad",
    technical: "Técnica",
    certification: "Certificación",
    complementary: "Complementario",
};
const translatedEducation = (educationEntries ?? []).map((e: any) => ({
    ...e,
    title: t(e.title, "es"),
    institution: t(e.institution, "es"),
    description: e.description ? t(e.description, "es") : null,
}));
const hasEducation = translatedEducation.length > 0;

const showStack = (technologies?.length ?? 0) > 0;
let _sn = 0;
const sn = (visible = true) => (visible ? String(++_sn).padStart(3, "0") : "");
const numWork = sn();
const numStack = sn(showStack);
const numEducation = sn(hasEducation);
const numContact = sn();

const uiDictionary = {
    projects: "Ver proyectos",
    github: "Ver GitHub",
    resume: "Descargar CV",
    problem: "Problema",
    architecture: "Arquitectura",
    outcome: "Resultado",
    privateRepo: "Privado",
    stackTitle: "Stack Tecnológico",
    viewCredential: "Ver Credencial",
    contactTitle: "Ponte en Contacto",
    contactName: "Nombre Completo",
    contactEmail: "Correo Electrónico",
    contactMessage: "Tu Mensaje",
    contactSubmit: "Enviar Mensaje",
    contactSuccess:
        "¡Mensaje enviado correctamente! Me pondré en contacto pronto.",
    contactError:
        "Hubo un error al enviar el mensaje. Por favor intenta de nuevo.",
    showMore: "Ver todos los proyectos",
    educationTitle: "Educación",
    seeMore: "Ver más",
    close: "Cerrar",
    summary: "Resumen",
};
---

<Layout
    title="echo-whoami — Portafolio"
    lang="es"
    description="Ingeniero de software y especialista en datos. Proyectos, stack y contacto."
>
    <div class="min-h-screen flex flex-col font-sans">
        <Header lang="es" />
        <main class="grow flex flex-col font-sans">
            {
                translatedProfile && (
                    <Hero
                        bio={translatedProfile.bio}
                        resumeUrl={translatedProfile.resume_url || "#"}
                        githubUrl={translatedProfile.github_url || "#"}
                        avatarUrl={profile?.avatar_url || undefined}
                        displayName={profile?.display_name || undefined}
                        t={uiDictionary}
                    />
                )
            }

            <section
                id="proyectos"
                class="max-w-5xl mx-auto px-4 sm:px-6 py-20 w-full flex flex-col gap-10 reveal-hidden"
            >
                <div class="flex flex-col gap-2">
                    <p
                        class="font-mono text-xs tracking-widest"
                        style="color: var(--text-muted);"
                    >
                        {numWork} — trabajo
                    </p>
                    <h2
                        class="text-3xl md:text-4xl font-black tracking-tight"
                        style="color: var(--text-primary);"
                    >
                        {uiDictionary.projects}
                    </h2>
                </div>

                <div class="projects-outer">
                    {allDisplayProjects.map((project, i) => (
                        <div class:list={["project-wrap", { "project-featured": i === 0 }]}>
                            <ProjectCard project={project} t={uiDictionary} />
                        </div>
                    ))}
                </div>
            </section>

            {
                technologies && technologies.length > 0 && (
                    <section
                        id="stack"
                        class="max-w-5xl mx-auto px-4 sm:px-6 py-20 w-full reveal-hidden"
                        style="border-top: 1px solid var(--border-subtle);"
                    >
                        <div class="flex flex-col gap-2 mb-10">
                            <p
                                class="font-mono text-xs tracking-widest"
                                style="color: var(--text-muted);"
                            >
                                {numStack} — stack
                            </p>
                            <h2
                                class="text-3xl md:text-4xl font-black tracking-tight"
                                style="color: var(--text-primary);"
                            >
                                {uiDictionary.stackTitle}
                            </h2>
                        </div>
                        <StackSection technologies={technologies} />
                    </section>
                )
            }

            {
                hasEducation && (
                    <section
                        id="educacion"
                        class="max-w-5xl mx-auto px-4 sm:px-6 py-20 w-full reveal-hidden"
                        style="border-top: 1px solid var(--border-subtle);"
                    >
                        <div class="flex flex-col gap-2 mb-12">
                            <p
                                class="font-mono text-xs tracking-widest"
                                style="color: var(--text-muted);"
                            >
                                {numEducation} — Experiencia y Formacion
                            </p>
                            <h2
                                class="text-3xl md:text-4xl font-black tracking-tight"
                                style="color: var(--text-primary);"
                            >
                                {uiDictionary.educationTitle}
                            </h2>
                        </div>
                        <EducationTimeline
                            entries={translatedEducation}
                            categoryLabels={EDUCATION_CATEGORY_LABELS}
                            viewCredential={uiDictionary.viewCredential}
                            presentLabel="presente"
                        />
                    </section>
                )
            }

            <section
                id="contacto"
                class="max-w-5xl mx-auto px-4 sm:px-6 py-20 w-full reveal-hidden"
                style="border-top: 1px solid var(--border-subtle);"
            >
                <ContactForm
                    sectionLabel={`${numContact} — contacto`}
                    linkedinUrl={(profile as any)?.linkedin_url || undefined}
                    githubUrl={profile?.github_url || undefined}
                    emailUrl={(profile as any)?.contact_email || undefined}
                    t={{
                        title: uiDictionary.contactTitle,
                        nameLabel: uiDictionary.contactName,
                        emailLabel: uiDictionary.contactEmail,
                        messageLabel: uiDictionary.contactMessage,
                        submitText: uiDictionary.contactSubmit,
                        successMessage: uiDictionary.contactSuccess,
                        errorMessage: uiDictionary.contactError,
                    }}
                />
            </section>
        </main>
        <Footer />
    </div>
</Layout>
