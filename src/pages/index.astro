---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import ProjectCard from "../components/ProjectCard.astro";
import CertificationCard from "../components/CertificationCard.astro";
import StackSection from "../components/StackSection.astro";
import ContactForm from "../components/ContactForm.astro";
import EducationTimeline from "../components/EducationTimeline.astro";
import Footer from "../components/Footer.astro";
import {
	getProfile,
	getFeaturedProjects,
	getPublishedProjects,
	getPublishedCertifications,
	getAllTechnologies,
	getPublishedEducation,
} from "../services/api";
import { t } from "../utils/i18n";

const profile = await getProfile();
const featuredProjects = await getFeaturedProjects();
const allProjects = await getPublishedProjects();
const certifications = await getPublishedCertifications();
const technologies = await getAllTechnologies();
const educationEntries = await getPublishedEducation();

const translatedProfile = profile
	? {
			...profile,
			bio: t(profile.bio, "en"),
			resume_url: t(profile.resume_url, "en"),
	  }
	: null;

const hasFeatured = (featuredProjects?.length ?? 0) > 0;
const initialProjects = hasFeatured ? featuredProjects : (allProjects?.slice(0, 4) ?? []);
const remainingProjects = hasFeatured
	? allProjects?.filter(p => !featuredProjects?.find(f => f.id === p.id)) ?? []
	: allProjects?.slice(4) ?? [];

const translateProject = (project: any) => ({
	...project,
	title: t(project.title, "en"),
	summary: t(project.summary, "en"),
	problem: t(project.problem, "en"),
	architecture: t(project.architecture, "en"),
	outcome: t(project.outcome, "en"),
});

const translatedInitialProjects = initialProjects.map(translateProject);
const translatedRemainingProjects = remainingProjects.map(translateProject);

const translatedCertifications = certifications?.map((cert) => ({
	...cert,
	title: t(cert.title, "en"),
}));

const EDUCATION_CATEGORY_LABELS: Record<string, string> = {
	university: 'University',
	technical: 'Technical',
	certification: 'Certification',
	complementary: 'Complementary',
};
const translatedEducation = (educationEntries ?? []).map((e: any) => ({
	...e,
	title: t(e.title, 'en'),
	institution: t(e.institution, 'en'),
	description: e.description ? t(e.description, 'en') : null,
}));
const hasEducation = translatedEducation.length > 0;

const showCerts = (translatedCertifications?.length ?? 0) > 0;
const showStack = (technologies?.length ?? 0) > 0;
let _sn = 0;
const sn = (visible = true) => visible ? String(++_sn).padStart(3, '0') : '';
const numWork     = sn();
const numCerts    = sn(showCerts);
const numStack    = sn(showStack);
const numEducation = sn(hasEducation);
const numContact  = sn();

const uiDictionary = {
	projects: "View Projects",
	github: "GitHub",
	resume: "Download CV",
	problem: "Problem",
	architecture: "Architecture",
	outcome: "Outcome",
	privateRepo: "Private repository",
	certificationsTitle: "Certifications",
	stackTitle: "Tech Stack",
	viewCredential: "View Credential",
	contactTitle: "Get in Touch",
	contactName: "Full Name",
	contactEmail: "Email Address",
	contactMessage: "Your Message",
	contactSubmit: "Send Message",
	contactSuccess: "Message sent successfully! I'll get back to you soon.",
	contactError: "There was an error sending the message. Please try again.",
	showMore: "Show all projects",
	educationTitle: "Education",
};
---

<Layout
	title="echo-whoami — Portfolio"
	lang="en"
	description="Software engineer & data specialist. Projects, stack and contact."
>
	<div class="min-h-screen flex flex-col font-sans">
		<Header lang="en" />
		<main class="grow flex flex-col font-sans">
			{
				translatedProfile && (
					<Hero
						bio={translatedProfile.bio}
						resumeUrl={translatedProfile.resume_url || "#"}
						githubUrl={translatedProfile.github_url || "#"}
						avatarUrl={profile?.avatar_url || undefined}
						displayName={profile?.display_name || undefined}
						t={uiDictionary}
					/>
				)
			}

			<section
				id="proyectos"
				class="max-w-5xl mx-auto px-4 sm:px-6 py-20 w-full flex flex-col gap-10 reveal-hidden"
			>
				<div class="flex flex-col gap-2">
					<p
						class="font-mono text-xs tracking-widest"
						style="color: var(--text-muted);"
					>
						{numWork} — work
					</p>
					<h2
						class="text-3xl md:text-4xl font-black tracking-tight"
						style="color: var(--text-primary);"
					>
						{uiDictionary.projects}
					</h2>
				</div>

				<div class="grid grid-cols-1 lg:grid-cols-2 gap-6" id="projects-initial">
					{
						translatedInitialProjects.map((project) => (
							<ProjectCard project={project} t={uiDictionary} />
						))
					}
				</div>

				{translatedRemainingProjects.length > 0 && (
					<>
						<div class="grid grid-cols-1 lg:grid-cols-2 gap-6 hidden" id="projects-more">
							{translatedRemainingProjects.map((project) => (
								<ProjectCard project={project} t={uiDictionary} />
							))}
						</div>
						<div class="flex justify-center">
							<button
								id="show-more-btn"
								class="font-mono text-xs tracking-widest px-8 py-3 transition-all duration-200"
								style="border: 1px solid var(--border-default); color: var(--text-secondary); background: transparent;"
							>
								{uiDictionary.showMore} ({translatedRemainingProjects.length})
							</button>
						</div>
					</>
				)}
			</section>

			<script>
				const btn = document.getElementById('show-more-btn');
				const more = document.getElementById('projects-more');
				if (btn && more) {
					btn.addEventListener('click', () => {
						more.classList.remove('hidden');
						btn.parentElement?.remove();
					});
				}
			</script>

			{
				translatedCertifications && translatedCertifications.length > 0 && (
					<section
						id="certifications"
						class="max-w-5xl mx-auto px-4 sm:px-6 py-20 w-full flex flex-col gap-10 reveal-hidden"
						style="border-top: 1px solid var(--border-subtle);"
					>
						<div class="flex flex-col gap-2">
							<p
								class="font-mono text-xs tracking-widest"
								style="color: var(--text-muted);"
							>
								{numCerts} — certifications
							</p>
							<h2
								class="text-3xl md:text-4xl font-black tracking-tight"
								style="color: var(--text-primary);"
							>
								{uiDictionary.certificationsTitle}
							</h2>
						</div>
						<div class="flex flex-col">
							{translatedCertifications.map((cert, i) => (
								<CertificationCard
									certification={cert}
									index={i}
									t={uiDictionary}
								/>
							))}
						</div>
					</section>
				)
			}

			{
				technologies && technologies.length > 0 && (
					<section
						id="stack"
						class="max-w-5xl mx-auto px-4 sm:px-6 py-20 w-full reveal-hidden"
						style="border-top: 1px solid var(--border-subtle);"
					>
						<div class="flex flex-col gap-2 mb-10">
							<p
								class="font-mono text-xs tracking-widest"
								style="color: var(--text-muted);"
							>
								{numStack} — stack
							</p>
							<h2
								class="text-3xl md:text-4xl font-black tracking-tight"
								style="color: var(--text-primary);"
							>
								{uiDictionary.stackTitle}
							</h2>
						</div>
						<StackSection technologies={technologies} />
					</section>
				)
			}

			{
				hasEducation && (
					<section
						id="education"
						class="max-w-5xl mx-auto px-4 sm:px-6 py-20 w-full reveal-hidden"
						style="border-top: 1px solid var(--border-subtle);"
					>
						<div class="flex flex-col gap-2 mb-12">
							<p class="font-mono text-xs tracking-widest" style="color: var(--text-muted);">
								{numEducation} — Experience & Training
							</p>
							<h2 class="text-3xl md:text-4xl font-black tracking-tight" style="color: var(--text-primary);">
								{uiDictionary.educationTitle}
							</h2>
						</div>
						<EducationTimeline
							entries={translatedEducation}
							categoryLabels={EDUCATION_CATEGORY_LABELS}
							viewCredential={uiDictionary.viewCredential}
							presentLabel="present"
						/>
					</section>
				)
			}

			<section
				id="contact"
				class="max-w-5xl mx-auto px-4 sm:px-6 py-20 w-full reveal-hidden"
				style="border-top: 1px solid var(--border-subtle);"
			>
				<ContactForm
					sectionLabel={`${numContact} — contact`}
					linkedinUrl={(profile as any)?.linkedin_url || undefined}
					githubUrl={profile?.github_url || undefined}
					emailUrl={(profile as any)?.contact_email || undefined}
					t={{
						title: uiDictionary.contactTitle,
						nameLabel: uiDictionary.contactName,
						emailLabel: uiDictionary.contactEmail,
						messageLabel: uiDictionary.contactMessage,
						submitText: uiDictionary.contactSubmit,
						successMessage: uiDictionary.contactSuccess,
						errorMessage: uiDictionary.contactError,
					}}
				/>
			</section>
		</main>
		<Footer />
	</div>
</Layout>
