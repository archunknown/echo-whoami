---
interface Technology {
    id: string;
    name: string;
    category?: string | null;
    color?: string | null;
    icon_slug?: string | null;
    logo_url?: string | null;
}
interface Props {
    technologies: Technology[];
}
const { technologies } = Astro.props;

// Deterministic vertical offsets and animation delays for organic feel
const offsets = [0, 8, -4, 12, -8, 4, 10, -6, 2, 8, -2, 6, -10, 5, -5, 9];
const delays =  [0, 0.7, 1.4, 2.1, 0.35, 1.05, 1.75, 2.45, 0.5, 1.2, 1.9, 0.15, 0.9, 1.6, 0.25, 1.3];
---

<div class="flex flex-wrap justify-center items-center gap-3 md:gap-4 reveal-hidden">
    {
        technologies.map((tech, i) => {
            const colorHex = (tech.color || "#888888").replace("#", "");
            const iconSrc = tech.logo_url
                ? tech.logo_url
                : tech.icon_slug
                ? `https://cdn.simpleicons.org/${tech.icon_slug}/${colorHex}`
                : null;

            const offset = offsets[i % offsets.length];
            const delay = delays[i % delays.length];

            return (
                <span
                    class="stack-badge inline-flex items-center gap-2 font-mono text-xs px-4 py-2 md:px-3 md:py-1.5 transition-all duration-300 hover:text-(--text-primary) hover:border-(--text-secondary)"
                    style={`margin-top: ${offset}px; animation-delay: ${delay}s; color: var(--text-secondary); border: 1px solid var(--border-default);`}
                    title={tech.name}
                >
                    {iconSrc && (
                        <img
                            src={iconSrc}
                            alt={tech.name}
                            width="14"
                            height="14"
                            loading="lazy"
                            style="object-fit: contain; flex-shrink: 0; opacity: 0.75;"
                            onerror="this.style.display='none'"
                        />
                    )}
                    {tech.name}
                </span>
            );
        })
    }
</div>
