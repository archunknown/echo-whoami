---
interface Props {
    t: {
        title?: string;
        nameLabel?: string;
        emailLabel?: string;
        messageLabel?: string;
        submitText?: string;
        successMessage?: string;
        errorMessage?: string;
    };
    sectionLabel?: string;
    linkedinUrl?: string;
    githubUrl?: string;
    emailUrl?: string;
}
const { t, sectionLabel, linkedinUrl, githubUrl, emailUrl } = Astro.props;
---

<div class="w-full max-w-xl reveal-hidden">

    <!-- Header (siempre visible) -->
    <div class="flex flex-col gap-2 mb-6">
        {sectionLabel && (
            <p class="font-mono text-xs tracking-widest" style="color: var(--text-muted);">
                {sectionLabel}
            </p>
        )}
        <h2 class="text-3xl md:text-4xl font-black tracking-tight" style="color: var(--text-primary);">
            {t.title || "Get in Touch"}
        </h2>
    </div>

    <!-- Botones de contacto (siempre visibles, incluso tras envío) -->
    {(linkedinUrl || githubUrl || emailUrl) && (
        <div class="flex flex-wrap gap-3 pb-6 mb-6" style="border-bottom: 1px solid var(--border-subtle);">
            {linkedinUrl && (
                <a
                    href={linkedinUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-2 font-mono text-xs tracking-widest transition-all duration-200 px-4 py-2.5 hover:border-(--text-secondary) hover:text-(--text-primary)"
                    style="color: var(--text-secondary); border: 1px solid var(--border-default);"
                >
                    <!-- LinkedIn icon -->
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                        <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                    </svg>
                    LinkedIn ↗
                </a>
            )}
            {githubUrl && (
                <a
                    href={githubUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-2 font-mono text-xs tracking-widest transition-all duration-200 px-4 py-2.5 hover:border-(--text-secondary) hover:text-(--text-primary)"
                    style="color: var(--text-secondary); border: 1px solid var(--border-default);"
                >
                    <!-- GitHub icon -->
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                        <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
                    </svg>
                    GitHub ↗
                </a>
            )}
            {emailUrl ? (
                <a
                    href={`mailto:${emailUrl}`}
                    class="inline-flex items-center gap-2 font-mono text-xs tracking-widest transition-all duration-200 px-4 py-2.5 hover:border-(--text-secondary) hover:text-(--text-primary)"
                    style="color: var(--text-secondary); border: 1px solid var(--border-default);"
                >
                    <!-- Email icon -->
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <rect x="2" y="4" width="20" height="16" rx="2"/>
                        <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
                    </svg>
                    Email ↗
                </a>
            ) : (
                <span
                    class="inline-flex items-center gap-2 font-mono text-xs tracking-widest px-4 py-2.5"
                    style="color: var(--text-muted); border: 1px solid var(--border-subtle);"
                >
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <rect x="2" y="4" width="20" height="16" rx="2"/>
                        <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
                    </svg>
                    Email ↓
                </span>
            )}
        </div>
    )}

    <!-- Mensaje de éxito -->
    <div id="success-message" class="hidden py-10 text-center">
        <p class="font-mono text-xs tracking-widest" style="color: var(--text-secondary);">
            message sent ✓
        </p>
    </div>

    <!-- Formulario -->
    <form id="contact-form" class="flex flex-col gap-6">
        <div
            id="error-message"
            class="hidden p-4 font-mono text-xs"
            style="color: #ff4444; border: 1px solid #ff444433;"
        >
        </div>

        <div class="flex flex-col gap-1">
            <label for="name" class="font-mono text-xs tracking-widest" style="color: var(--text-muted);">
                {t.nameLabel || "name"}
            </label>
            <input
                type="text"
                id="name"
                name="name"
                autocomplete="name"
                required
                class="w-full px-0 py-3 bg-transparent font-sans text-sm outline-none transition-colors duration-200"
                style="color: var(--text-primary); border-bottom: 1px solid var(--border-default);"
            />
        </div>

        <div class="flex flex-col gap-1">
            <label for="email" class="font-mono text-xs tracking-widest" style="color: var(--text-muted);">
                {t.emailLabel || "email"}
            </label>
            <input
                type="email"
                id="email"
                name="email"
                autocomplete="email"
                inputmode="email"
                required
                class="w-full px-0 py-3 bg-transparent font-sans text-sm outline-none transition-colors duration-200"
                style="color: var(--text-primary); border-bottom: 1px solid var(--border-default);"
            />
        </div>

        <div class="flex flex-col gap-1">
            <label for="message" class="font-mono text-xs tracking-widest" style="color: var(--text-muted);">
                {t.messageLabel || "message"}
            </label>
            <textarea
                id="message"
                name="message"
                rows="4"
                required
                class="w-full px-0 py-3 bg-transparent font-sans text-sm outline-none resize-none transition-colors duration-200"
                style="color: var(--text-primary); border-bottom: 1px solid var(--border-default);"
            ></textarea>
        </div>

        <button
            type="submit"
            id="submit-btn"
            class="w-full sm:w-fit inline-flex justify-center items-center px-6 py-4 sm:py-3 font-mono text-xs font-bold tracking-widest transition-all duration-200 mt-2 hover:bg-transparent hover:text-(--text-primary)"
            style="background: var(--text-primary); color: var(--bg-primary); border: 1px solid var(--text-primary);"
        >
            {t.submitText || "send"}
        </button>
    </form>
</div>

<script>
    const form = document.getElementById('contact-form') as HTMLFormElement | null;
    const successMsg = document.getElementById('success-message');
    const errorMsg   = document.getElementById('error-message');
    const submitBtn  = document.getElementById('submit-btn') as HTMLButtonElement | null;

    if (form && submitBtn && errorMsg && successMsg) {
        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            submitBtn.disabled = true;
            const originalText = submitBtn.innerText;
            submitBtn.innerText = '...';
            errorMsg.classList.add('hidden');

            const formData = new FormData(form);
            const payload = {
                name:    formData.get('name')?.toString().trim()    ?? '',
                email:   formData.get('email')?.toString().trim()   ?? '',
                message: formData.get('message')?.toString().trim() ?? '',
            };

            try {
                const res  = await fetch('/api/contact', {
                    method:  'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body:    JSON.stringify(payload),
                });
                const data = await res.json();

                if (!res.ok || data.error) {
                    throw new Error(data.error ?? 'Unknown error');
                }

                form.classList.add('hidden');
                successMsg.classList.remove('hidden');
            } catch (err: any) {
                errorMsg.textContent = err.message ?? 'error sending message. please try again.';
                errorMsg.classList.remove('hidden');
                submitBtn.disabled = false;
                submitBtn.innerText = originalText;
            }
        });
    }
</script>
